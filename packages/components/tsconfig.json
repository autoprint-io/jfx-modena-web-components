{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "paths": {
      "@autoprint/jfx-modena-design-system": [
        "../design-system/src/index.ts",
        "../../../../../packages/design-system/src/index.ts"
      ],
      "@autoprint/jfx-modena-runtime": [
        "../runtime/src/index.ts",
        "../../../../../packages/runtime/src/index.ts"
      ]
    },
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*.ts"]
}
